# --- Radi Coffee backend + bot config ---
# Скопируйте этот файл в .env и подставьте реальные значения.
# .env в git НЕ коммитится (см. .gitignore).

# Токен Telegram-бота от @BotFather (формат: <bot_id>:<секрет>)
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Telegram user id владельцев (через запятую). Владелец раздаёт роль баристам.
# Узнать свой id: напишите @userinfobot
OWNER_TG_IDS=11111111

# URL мини-аппа (открывается ботом)
WEBAPP_URL=https://example.com

# Адрес кофейни (на карточке лояльности)
CAFE_ADDRESS=ул. Примерная, 1

# Путь к БД (по умолчанию backend/data/radi.db)
# RADI_DB_PATH=/opt/radicoffee/data/radi.db

# Прокси для api.telegram.org, если из вашего региона он недоступен
# (формат http://user:pass@host:port). Обычно пусто.
TG_PROXY=

# CORS origins для локальной разработки (через запятую). В проде пусто (один origin).
# RADI_CORS=http://localhost:5183

# DEV: пропускать проверку подписи initData (ТОЛЬКО локально!). В проде = 0 или не задавать.
# RADI_DEV_AUTH=1
